{
  "name": "google-shadcn-translator",
  "version": "0.1.0",
  "description": "A React Google Translate widget wrapper with shadcn/ui select support.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./dist/styles.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react && node -e \"require('fs').copyFileSync('src/styles.css','dist/styles.css')\"",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --external react",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.2.0 || >=19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.0.0"
  }
}
